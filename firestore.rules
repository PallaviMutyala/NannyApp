rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — anyone logged in can read; only you can write your own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Daily logs — anyone logged in can read all logs (parent views nanny's entries)
    // Only the person who created a log can write/update it
    match /logs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.loggedBy == request.auth.uid;
    }
  }
}
