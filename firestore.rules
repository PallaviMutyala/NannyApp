rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the requesting user's familyId
    function myFamilyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Families — any authenticated user can read (needed for invite-code lookup at signup)
    // Only family members can update; anyone authenticated can create (signup flow)
    match /families/{familyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && myFamilyId() == familyId;
    }

    // Logs — one shared log per family per day (docId = familyId_date).
    // Any family member can read, create, edit, and delete their family's logs.
    match /logs/{logId} {
      // get on a missing doc has resource == null; allow if logId belongs to this family
      function isMyFamilyLogId() {
        return logId.matches('^' + myFamilyId() + '_.+');
      }
      allow read: if request.auth != null
        && (
          (resource != null && resource.data.familyId == myFamilyId())
          || (resource == null && isMyFamilyLogId())
        );
      allow create: if request.auth != null
        && request.resource.data.familyId == myFamilyId();
      allow update: if request.auth != null
        && resource.data.familyId == myFamilyId()
        && request.resource.data.familyId == resource.data.familyId;
      allow delete: if request.auth != null
        && resource.data.familyId == myFamilyId();
    }
  }
}
